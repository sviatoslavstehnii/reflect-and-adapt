# ── Google AI (required) ──────────────────────────────────────────────────────
# Get your API key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY="your-google-api-key"
GOOGLE_MODEL="gemini-3.1-pro"               # OpenClaw writers (proposal generation)
GOOGLE_MODEL_MINI="gemini-3-flash-preview"  # Memory writer
GOOGLE_EMBEDDING_MODEL="gemini-embedding-001" # Embeddings for vector memory

# ── Cortex Analyst — Qwen 3.5 Plus (required) ────────────────────────────────
# DashScope key from https://dashscope.console.aliyun.com
QWEN_API_KEY="your-qwen-api-key"
QWEN_MODEL="qwen-plus"

# ── Evaluation + User Simulation — Azure OpenAI (required) ───────────────────
# Azure OpenAI resource for GPT-4.1 (evaluator primary + simulator primary)
# Qwen 3.5 Plus is used as fallback for both if Azure errors
AZURE_OPENAI_ENDPOINT="https://<resource-name>.cognitiveservices.azure.com"
AZURE_OPENAI_INSTANCE_NAME="<resource-name>"
AZURE_OPENAI_API_KEY="your-azure-openai-api-key"
AZURE_OPENAI_DEPLOYMENT="gpt-4.1-mini"
AZURE_OPENAI_API_VERSION="2024-05-01-preview"

# ── LangSmith Tracing (optional) ─────────────────────────────────────────────
# Get your API key at https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY="lsv2_pt_..."
LANGCHAIN_PROJECT="reflect-and-adapt"

# ── Tuning (optional) ─────────────────────────────────────────────────────────
CORTEX_COOLDOWN_HOURS=1   # How often Cortex runs (default: 1)
